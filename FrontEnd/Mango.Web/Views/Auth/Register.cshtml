@using Mango.Web.Models;

@model RegistrationRequestDto

<form asp-action="Register" method="post">
    <div class="container border p-4">
        <div class="row text-center">
            <div class="col-md-12">
                <h1>Register</h1>
            </div>
        </div>
        <div class="row text-center">
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <input asp-for="Email" class="form-control" placeholder="Email..." />
                <asp-validation-for class="text-danger" asp-for="Email" />
            </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <input asp-for="Name" class="form-control" placeholder="Name..." />
                <asp-validation-for class="text-danger" asp-for="Name" />
            </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number..." />
                <asp-validation-for class="text-danger" asp-for="PhoneNumber" />
            </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <input asp-for="Password" class="form-control" placeholder="Password..." />
                <asp-validation-for class="text-danger" asp-for="Password" />
            </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <select asp-for="Role" class="form-select" asp-items="@ViewBag.RoleList">
                    <option disabled selected>--Select Role--</option>
                </select>
            </div>
            <div class="col-12 col-md-6 offset-md-3 pb-2">
                <button type="submit" class="form-control btn btn-success" value="Submit">Register</button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}